# Database Configuration (PostgreSQL on Supabase)
DATABASE_URL=postgresql://user:password@db.supabase.co:5432/postgres

# Supabase Client Configuration (Public/Anon Keys)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# AI Provider API Keys
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=your-gemini-api-key

# AI Provider Configuration
AI_DEFAULT_PROVIDER=openai
AI_DEFAULT_MODEL=gpt-4o

# Optional: Provider Failover Chain (comma-separated, for override)
# Default failover order: openai,gemini,anthropic
# AI_PROVIDER_CHAIN=openai,gemini,anthropic

# Optional: Anthropic API Key (for failover chain)
# ANTHROPIC_API_KEY=sk-ant-...
