{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,

    "types": ["vitest/globals", "node", "@cloudflare/workers-types"],
    "noEmit": true
  },
  "include": ["src", "setup.ts", "vitest.config.ts", "drizzle.config.ts", "src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "docs/index.edge.ts",
    "docs/cleanup.edge.ts",
    "docs/index.ts"
  ]
}
